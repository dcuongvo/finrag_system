# =========================
# API KEYS
# =========================
FINNHUB_API_KEY=KEY here
GOOGLE_API_KEY=KEY if use gemini

# =========================
# VECTOR STORE
# =========================
VECTOR_BACKEND=qdrant

# =========================
# ENVIRONMENT
# =========================
ENV=dev

# =========================
# LLM CONFIG
# =========================
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# (Switch to Ollama if use local llm)
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma4:e4b
# OLLAMA_BASE_URL=http://localhost:11434

# =========================
# EMBEDDING
# =========================
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5